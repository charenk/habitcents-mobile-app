# HabitCents environment (P2-3 analytics). Copy to `.env` (gitignored) to enable.
#
# Analytics are OFF unless EXPO_PUBLIC_POSTHOG_API_KEY is set. With no key the
# app makes zero network calls: PostHog is never imported and every track() call
# is a no-op. This preserves the "Data Not Collected" posture by default.
#
# Posture when enabled (decision 0002 / D-9): anonymous device-id mode only. We
# never call identify(); no PII is sent (amounts are coarse-bucketed, free text
# is stripped). Session replay and lifecycle autocapture are disabled in code.

# PostHog project API key (starts with `phc_`). Leave unset to keep analytics off.
EXPO_PUBLIC_POSTHOG_API_KEY=

# PostHog host. Defaults to US cloud when unset. Use https://eu.i.posthog.com for EU.
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Analytics debug logging.
#   Prints every tracked event + its sanitized payload to the Metro console, so
#   you can confirm events fire (and carry no PII) without opening PostHog.
#   Lines: "[analytics:dry-run] <event> {props}" = logged only, no key set;
#          "[analytics:sent]    <event> {props}" = also forwarded to PostHog.
#
#   Default: ON in development, OFF in production builds. Override here:
#     1 = force on  (e.g. to log from a preview/device build)
#     0 = force off (e.g. to quiet the dev console)
#   Restart the bundler with a cleared cache after changing: `npx expo start -c`.
# EXPO_PUBLIC_ANALYTICS_DEBUG=1

# ---------------------------------------------------------------------------
# Purchases / RevenueCat (BET-004, Phase 3 monetization). MOCK MODE by default.
#
# With no key, utils/purchases.ts runs in mock mode: getEntitlement() always
# returns 'free', and purchase()/restore() log '[purchases:mock]' and resolve
# success so the paywall and entitlement gate work end to end. No native SDK is
# imported and no charge is ever made. The live implementation (a dynamic import
# of react-native-purchases) lands when this key is supplied.
# ---------------------------------------------------------------------------

# RevenueCat public SDK key (iOS/Android). Leave unset to keep mock mode.
EXPO_PUBLIC_REVENUECAT_API_KEY=

# Product identifiers (must match the products created in RevenueCat / the
# stores). Defaults are the placeholders referenced in utils/purchases.ts.
# EXPO_PUBLIC_REVENUECAT_PRODUCT_MONTHLY=habitcents_premium_monthly
# EXPO_PUBLIC_REVENUECAT_PRODUCT_ANNUAL=habitcents_premium_annual
# EXPO_PUBLIC_REVENUECAT_PRODUCT_LIFETIME=habitcents_premium_lifetime
